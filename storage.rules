rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // All authenticated users can read/write job photos and installer files.
    // Accounts are admin-provisioned so any Firebase auth user is trusted.
    match /jobs/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    match /installers/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    // --------------------------------------------------------
    // Deny everything else by default
    // --------------------------------------------------------
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
