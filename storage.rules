rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Job photos and signatures
    // Only authenticated users (provisioned installers + admin) can read/write.
    // Public access is blocked. Account provisioning is controlled by the admin,
    // so all authenticated users are trusted.
    match /jobs/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    // Installer profile files (signatures, profile photos)
    match /installers/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    // Deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
