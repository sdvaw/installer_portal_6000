rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Job photos — any authenticated user can read (portal + reports display)
    // Write open to all authenticated users (all accounts are admin-provisioned)
    match /jobs/{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null;
    }

    // Installer profile signatures — stored by Firebase UID, no Firestore lookup needed
    match /installer_signatures/{uid}/{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Installer files (compliance docs, legacy signatures) — read: any auth user
    // Write: admin, or the owning installer (matched by firebaseUid or email)
    match /installers/{installerId}/{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && (
        request.auth.uid == 'yKCWdsUceONZJtysdweYW2vamFV2' ||
        firestore.get(/databases/(default)/documents/installers/$(installerId)).data.get('firebaseUid', null) == request.auth.uid ||
        firestore.get(/databases/(default)/documents/installers/$(installerId)).data.get('email', null) == request.auth.token.email
      );
    }

    // Archives — admin only
    match /archives/{allPaths=**} {
      allow read, write: if request.auth != null
        && request.auth.uid == 'yKCWdsUceONZJtysdweYW2vamFV2';
    }

    // Deny everything else by default
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
